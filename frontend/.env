# API Configuration
API_BASE_URL=http://localhost:8000/api
API_TIMEOUT=30000

# Authentication
TOKEN_KEY=auth_token
REFRESH_TOKEN_KEY=refresh_token

# App Settings
APP_NAME=Music Player
APP_VERSION=1.0.0

# Storage Keys
USER_PREFERENCES_KEY=user_preferences
PLAYLIST_STORAGE_KEY=playlists
RECENTLY_PLAYED_KEY=recently_played

# Audio Settings
DEFAULT_VOLUME=1.0
CROSSFADE_DURATION=2

# Cache Settings
CACHE_DURATION_HOURS=24
MAX_CACHE_SIZE_MB=100

# Development Mode
DEBUG_MODE=true
LOG_API_REQUESTS=true
