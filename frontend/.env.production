# Production Environment Configuration for Flutter App
# This file contains environment variables for the production build

# API Configuration
API_BASE_URL=http://localhost:8000/api
API_TIMEOUT=30000

# App Configuration
APP_NAME=Music Player
APP_VERSION=1.0.0
ENVIRONMENT=production

# Debug Settings
DEBUG_MODE=false
LOG_LEVEL=error

# Feature Flags
ENABLE_OFFLINE_MODE=true
ENABLE_ANALYTICS=false
ENABLE_CRASH_REPORTING=false

# Security
SECURE_STORAGE=true
REQUIRE_SSL=true

# Performance
CACHE_DURATION=3600
MAX_CACHE_SIZE=100

# UI Configuration
DEFAULT_THEME=dark
ENABLE_DYNAMIC_COLORS=true

# Audio Configuration
MAX_PLAYBACK_QUALITY=high
ENABLE_GAPLESS_PLAYBACK=true
DEFAULT_VOLUME=0.8

# Library Configuration
MAX_LIBRARY_SIZE=10000
ENABLE_AUTO_SCAN=false
SUPPORTED_FORMATS=mp3,m4a,flac,wav,ogg,aac

# Network Configuration
CONNECTION_TIMEOUT=30000
RETRY_ATTEMPTS=3
ENABLE_COMPRESSION=true

# Storage Paths
CACHE_PATH=/data/user/0/com.example.music_player_app/cache
FILES_PATH=/data/user/0/com.example.music_player_app/files

# Database Configuration
DATABASE_NAME=music_player.db
DATABASE_VERSION=1

# Logging
LOG_TO_FILE=false
LOG_RETENTION_DAYS=7

# Build Information
BUILD_NUMBER=1
BUILD_TYPE=release
COMPILE_SDK=34
TARGET_SDK=34
MIN_SDK=21
