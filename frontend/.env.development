# Environment Configuration for Music Player App - Development

# API Configuration
API_BASE_URL=http://localhost:8000/api
API_TIMEOUT=30000

# Debug Settings
DEBUG_MODE=true
ENABLE_LOGGING=true
LOG_LEVEL=debug

# App Configuration
APP_NAME=Music Player Dev
APP_VERSION=1.0.0

# Feature Flags
ENABLE_OFFLINE_MODE=true
ENABLE_METADATA_EXTRACTION=true
ENABLE_SONG_MATCHING=true

# Authentication
ENABLE_AUTH=true
AUTH_TIMEOUT=60000

# Storage
ENABLE_SECURE_STORAGE=true
CACHE_DURATION_DAYS=7

# Audio Player
ENABLE_BACKGROUND_PLAYBACK=true
MAX_CACHE_SIZE_MB=500

# Development Settings
MO_API_ENABLED=false
MOCK_DATA_ENABLED=false

# Server Connection
RETRY_ATTEMPTS=3
RETRY_DELAY_MS=1000

# Platform Specific
PLATFORM=android
DEVICE_NAME=Pixel_10_Pro_XL
