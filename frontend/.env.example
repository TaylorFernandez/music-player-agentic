# Music Player App - Environment Configuration
# Copy this file to .env and fill in your values

# ============================================
# Backend API Configuration
# ============================================

# Django backend API URL
# For local development: http://localhost:8000/api
# For production: https://your-domain.com/api
API_BASE_URL=http://localhost:8000/api

# API Version (optional)
API_VERSION=v1

# ============================================
# Authentication Configuration
# ============================================

# OAuth Configuration (if using Google Sign-In)
# Get these from Google Cloud Console
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# JWT Token Expiration (in seconds)
# Default: 7 days = 604800 seconds
TOKEN_EXPIRATION=604800

# ============================================
# App Configuration
# ============================================

# App Name (displayed in UI)
APP_NAME=Music Player

# App Version
APP_VERSION=1.0.0

# Debug Mode (set to false for production)
DEBUG=true

# ============================================
# Storage Configuration
# ============================================

# Local Storage Path (optional)
# Defaults to app's document directory if not set
# STORAGE_PATH=/path/to/music/library

# Maximum Cache Size (in MB)
MAX_CACHE_SIZE=500

# ============================================
# Audio Player Configuration
# ============================================

# Audio Buffer Size (in KB)
# Larger buffer = smoother playback but more memory
AUDIO_BUFFER_SIZE=256

# Enable Background Audio (true/false)
ENABLE_BACKGROUND_AUDIO=true

# ============================================
# Metadata Service Configuration
# ============================================

# Enable Metadata Extraction
ENABLE_METADATA_EXTRACTION=true

# Supported Audio Formats (comma-separated)
SUPPORTED_FORMATS=mp3,m4a,flac,wav,ogg,aac

# ============================================
# Song Matching Service Configuration
# ============================================

# Minimum Confidence Score (0.0 to 1.0)
# Only matches above this threshold will be accepted
MIN_CONFIDENCE_SCORE=0.7

# Enable Fuzzy Matching
ENABLE_FUZZY_MATCHING=true

# ============================================
# Library Service Configuration
# ============================================

# Auto-Scan Library on Startup
AUTO_SCAN_LIBRARY=false

# Scan Directories (comma-separated paths)
# Example: /storage/emulated/0/Music,/sdcard/Music
# Leave empty to use system default music directories
SCAN_DIRECTORIES=

# ============================================
# Logging Configuration
# ============================================

# Log Level (debug, info, warning, error)
LOG_LEVEL=debug

# Enable Crash Reporting (true/false)
ENABLE_CRASH_REPORTING=false

# ============================================
# Feature Flags
# ============================================

# Enable Offline Mode
ENABLE_OFFLINE_MODE=true

# Enable Lyrics Display
ENABLE_LYRICS=true

# Enable Artwork Display
ENABLE_ARTWORK=true

# Enable Artist Biographies
ENABLE_ARTIST_BIO=true

# ============================================
# Network Configuration
# ============================================

# Connection Timeout (in seconds)
CONNECTION_TIMEOUT=30

# Request Timeout (in seconds)
REQUEST_TIMEOUT=60

# Retry Attempts for Failed Requests
RETRY_ATTEMPTS=3

# ============================================
# Development/Testing Configuration
# ============================================

# Mock Data Mode (for testing without backend)
MOCK_DATA=false

# Enable Network Logging
ENABLE_NETWORK_LOGGING=true

# Enable Performance Monitoring
ENABLE_PERFORMANCE_MONITORING=false
```

