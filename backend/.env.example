# =============================================================================
# Music Player Backend - Environment Configuration Template
# =============================================================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control!
# =============================================================================

# =============================================================================
# DJANGO CORE SETTINGS
# =============================================================================

# Django Secret Key - Generate a new one for production!
# Generate with: python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'
SECRET_KEY=your-secret-key-here-change-this-in-production

# Debug mode - Set to False in production!
DEBUG=False

# Allowed hosts - Comma-separated list of domain names
# Example: example.com,www.example.com,api.example.com
ALLOWED_HOSTS=localhost,127.0.0.1

# =============================================================================
# DATABASE SETTINGS (PostgreSQL)
# =============================================================================

# Database name
DB_NAME=musicplayer

# Database user
DB_USER=musicplayer

# Database password - CHANGE THIS!
DB_PASSWORD=your-secure-password-here

# Database host (default: localhost)
DB_HOST=localhost

# Database port (default: 5432)
DB_PORT=5432

# =============================================================================
# CORS SETTINGS
# =============================================================================

# Allowed CORS origins - Comma-separated list of frontend URLs
# Example: http://localhost:3000,https://example.com
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# =============================================================================
# EMAIL SETTINGS
# =============================================================================

# Email backend (SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password-here
DEFAULT_FROM_EMAIL=noreply@musicplayer.com

# =============================================================================
# ADMIN SETTINGS
# =============================================================================

# Admin name and email for error notifications
ADMIN_NAME=Admin
ADMIN_EMAIL=admin@musicplayer.com

# =============================================================================
# OPTIONAL SERVICES
# =============================================================================

# Redis (for caching and Celery)
# REDIS_URL=redis://127.0.0.1:6379/1

# Sentry (for error tracking)
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# Celery (for background tasks)
# CELERY_BROKER_URL=redis://localhost:6379/0
# CELERY_RESULT_BACKEND=redis://localhost:6379/0

# =============================================================================
# FLUTTER/FRONTEND SETTINGS
# =============================================================================

# Frontend URL (for CORS and redirects)
FRONTEND_URL=http://localhost:3000

# API URL (for frontend to connect to backend)
API_URL=http://localhost:8000

# =============================================================================
# MEDIA AND STATIC FILES
# =============================================================================

# Media URL (user uploads)
MEDIA_URL=/media/

# Static URL (CSS, JS, images)
STATIC_URL=/static/

# =============================================================================
# SECURITY SETTINGS
# =============================================================================

# HTTPS settings (set to True if using HTTPS)
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False

# =============================================================================
# LOGGING
# =============================================================================

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# =============================================================================
# PERFORMANCE SETTINGS
# =============================================================================

# Database connection pool size
DB_CONN_MAX_AGE=600

# Cache timeout (seconds)
CACHE_TIMEOUT=300

# =============================================================================
# DEVELOPMENT ONLY (Remove in production)
# =============================================================================

# Enable Django Debug Toolbar (development only)
# DEBUG_TOOLBAR=True

# =============================================================================
# NOTES
# =============================================================================
#
# For production:
# 1. Set DEBUG=False
# 2. Generate a new SECRET_KEY
# 3. Set up PostgreSQL database
# 4. Configure email backend
# 5. Set SECURE_SSL_REDIRECT=True
# 6. Set SESSION_COOKIE_SECURE=True
# 7. Set CSRF_COOKIE_SECURE=True
# 8. Configure ALLOWED_HOSTS properly
# 9. Set up HTTPS certificates
# 10. Configure backup and monitoring
#
# Database setup:
# CREATE DATABASE musicplayer;
# CREATE USER musicplayer WITH PASSWORD 'your-password';
# GRANT ALL PRIVILEGES ON DATABASE musicplayer TO musicplayer;
#
# Email setup (Gmail example):
# 1. Enable 2-Factor Authentication
# 2. Generate an App Password
# 3. Use the App Password in EMAIL_HOST_PASSWORD
