# Django Core Settings
SECRET_KEY=django-insecure-change-this-in-production-use-python-secrets-token-urlsafe-32
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database Settings (PostgreSQL)
DB_NAME=musicplayer
DB_USER=musicplayer
DB_PASSWORD=musicplayer123
DB_HOST=localhost
DB_PORT=5432

# CORS Settings
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080,http://localhost:5000

# Email Settings (Configure for production)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=noreply@musicplayer.com

# Admin Settings
ADMIN_NAME=Admin
ADMIN_EMAIL=admin@musicplayer.com

# Security Settings (Set to True in production)
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False

# Logging
LOG_LEVEL=INFO

# Frontend URL (for CORS and redirects)
FRONTEND_URL=http://localhost:3000

# API URL (for frontend to connect to backend)
API_URL=http://localhost:8000

# Media and Static Files
MEDIA_URL=/media/
STATIC_URL=/static/
